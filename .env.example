# TracePoint — Variables de entorno
# Copia este archivo como .env y completa los valores.
#
# Leyenda:
#   [REQUERIDO]  La app no funciona correctamente sin este valor.
#   [RECOMENDADO] Funciona sin él, pero con capacidades limitadas.
#   [OPCIONAL]   Tiene un valor por defecto razonable.


# ─────────────────────────────────────────────────────────────
# SEGURIDAD
# ─────────────────────────────────────────────────────────────

# [REQUERIDO] Clave secreta para firmar tokens de sesión y 2FA.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-segura


# ─────────────────────────────────────────────────────────────
# INTELIGENCIA ARTIFICIAL — OpenRouter
# ─────────────────────────────────────────────────────────────
# Sin esta key el análisis IA queda deshabilitado (el resto funciona).
# Registro gratuito en: https://openrouter.ai/
#
# [RECOMENDADO]
OPENROUTER_API_KEY=

# [OPCIONAL] Identificación de tu instancia en las cabeceras HTTP de OpenRouter.
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_SITE_NAME=TracePoint

# [OPCIONAL] Modelos usados según el tipo de análisis.
# Texto/correlación general:
OPENROUTER_MODEL_TEXT=deepseek/deepseek-v4-flash
# Análisis con imágenes:
OPENROUTER_MODEL_VISION=google/gemini-3.5-flash
# Análisis profundo (deep search):
OPENROUTER_MODEL_EXTREME=anthropic/claude-opus-4.7


# ─────────────────────────────────────────────────────────────
# HAVE I BEEN PWNED — Detección de brechas de datos
# ─────────────────────────────────────────────────────────────
# Sin esta key la búsqueda por email retorna status "no_api_key"
# en lugar de datos de brechas. El resto del módulo de email funciona.
#
# Key de pago en: https://haveibeenpwned.com/API/Key
# Plan mínimo (~$3.50/mes) es suficiente para uso personal.
#
# [RECOMENDADO]
HIBP_API_KEY=


# ─────────────────────────────────────────────────────────────
# TOR — Búsqueda en deep web (.onion)
# ─────────────────────────────────────────────────────────────
# Requiere tener Tor instalado y corriendo localmente.
# Arch Linux: sudo pacman -S tor && sudo systemctl start tor
#
# Si no usas deep web, deja estos valores por defecto.
#
# [OPCIONAL]
TOR_HOST=127.0.0.1
TOR_PORT=9050
TOR_CONTROL_PORT=9051
TOR_PASSWORD=


# ─────────────────────────────────────────────────────────────
# DESARROLLO
# ─────────────────────────────────────────────────────────────

# [OPCIONAL] Activa el modo debug de FastAPI (recarga automática, errores detallados).
# No usar en producción.
DEBUG=false
